# ── Wallet ─────────────────────────────────────────────────────────────────────
# WARNING: Never commit your real private key. Use a dedicated trading wallet.
PRIVATE_KEY=your_private_key_here

# ── Network ────────────────────────────────────────────────────────────────────
# Leave blank to use the default public RPC for the selected network.
# For production, use a private RPC (e.g. Alchemy, QuickNode, Coinbase Developer Platform).
BASE_RPC_URL=
TESTNET=false

# ── Trading ────────────────────────────────────────────────────────────────────
TRADE_TOKEN=USDC
TRADE_AMOUNT_ETH=0.01
MAX_SLIPPAGE_PERCENT=0.5
POLLING_INTERVAL_SECONDS=60

# ── Safety ─────────────────────────────────────────────────────────────────────
# Set to false only when you are ready to trade with real funds.
DRY_RUN=true

# ── Strategy ───────────────────────────────────────────────────────────────────
STRATEGY=combined
LOG_LEVEL=INFO
